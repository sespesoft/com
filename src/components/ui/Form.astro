---
import type { Form } from '~/types';
import Button from '~/components/ui/Button.astro';

const { inputs, textarea, disclaimer, button = 'Enviar Mensaje', description = '' } = Astro.props as Form;
---

<form id="my-form" action="https://formspree.io/f/mldbbkyp" method="POST" class="needs-validation" novalidate>
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <div class="mb-1">
              {label && (
                <label for={name} class="block text-sm font-medium mb-2 text-[#1a202ccc] dark:text-white">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={name}
                autocomplete={autocomplete}
                placeholder={placeholder}
                pattern={type === 'email' ? '^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$' : undefined}
                class="py-3 px-4 block w-full text-sm rounded-md border-2 border-solid border-[#ff880033] border-l-[#ff8800a8] bg-[#ff88000d] duration-300 focus:outline-none focus:border-[#ff8800a2] focus:ring-[#ff8800a2] dark:border-gray-700 dark:bg-slate-900"
                required
              />
              <div class="field-feedback text-red-400 text-xs mt-1" data-type={type}>
                Campo requerido.
              </div>
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for="textarea" class="block text-sm font-medium mb-2 text-[#1a202ccc] dark:text-white">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name="message"
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          class="py-3 px-4 block w-full text-sm rounded-md border-2 border-solid border-[#ff880033] border-l-[#ff8800a8] bg-[#ff88000d] duration-300 focus:outline-hidden focus:border-[#ff8800a2] focus:ring-[#ff8800a2] dark:border-gray-700 dark:bg-slate-900"
          required
        />
        <div class="empty-feedback text-red-400 text-xs mt-1" data-type="text">
          Campo requerido.
        </div>
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer mt-1 py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="mt-10 grid">
        <div class="flex justify-center">
          <div
            class="g-recaptcha hidden"
            data-sitekey="6LdfoTErAAAAAPrzJimGg1rMdhah7aSt1oKQIHT2"
            data-size="invisible"
            data-callback="onRecaptchaSuccess"
            data-error-callback="onRecaptchaError"
          />
        </div>
        <div id="invalid-recaptcha" class="text-red-400 text-xs text-center" />
        <Button id="my-form-button" type="submit" variant="primary">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400">{description}</p>
      </div>
    )
  }
</form>

<script is:inline src="https://www.google.com/recaptcha/api.js" async defer></script>

<script is:inline>
  /* global grecaptcha */
  let form = document.getElementById('my-form');
  let button = document.getElementById('my-form-button');
  let status = document.getElementById('my-form-status');
  let invalidRecaptcha = document.getElementById('invalid-recaptcha');
  let formData = null;

  window.onRecaptchaSuccess = function (token) {
    if (!formData) return;
    formData.delete('g-recaptcha-response');
    formData.append('g-recaptcha-response', token);

    fetch(form.action, {
      method: form.method,
      body: formData,
      headers: {
        Accept: 'application/json',
      },
    })
      .then((response) => {
        if (response.ok) {
          form.reset();
          form.classList.remove('was-validated');
          invalidRecaptcha.innerHTML = '';
          grecaptcha.reset();

          const toast = document.getElementById('form-success-toast');
          if (toast) {
            toast.classList.remove('opacity-0', 'pointer-events-none');
            toast.classList.add('opacity-100');
            setTimeout(() => {
              toast.classList.add('opacity-0', 'pointer-events-none');
              toast.classList.remove('opacity-100');
            }, 4000);
          }
        } else {
          response.json().then((data) => {
            if (Object.hasOwn(data, 'errors')) {
              status.innerHTML = data['errors'].map((error) => error['message']).join(', ');
            } else {
              invalidRecaptcha.innerHTML = data.error || 'Error con reCAPTCHA.';
              grecaptcha.reset();
              setTimeout(() => {
                invalidRecaptcha.innerHTML = '';
              }, 5000);
            }
          });
        }
      })
      .catch((error) => {
        console.error(error);
        status.innerHTML = 'Oops! Hubo un problema al enviar el formulario.';
      })
      .finally(() => {
        button.disabled = false;
        formData = null;
      });
  };

  window.onRecaptchaError = function () {
    invalidRecaptcha.innerText = 'No se pudo validar el reCAPTCHA. Intenta nuevamente.';
    button.disabled = false;
  };

  async function handleSubmit(event) {
    event.preventDefault();

    if (!form.checkValidity()) {
      form.classList.add('was-validated');
      const firstInvalid = form.querySelector(':invalid');
      if (firstInvalid) firstInvalid.focus();
      return;
    }

    button.disabled = true;
    formData = new FormData(form);
    grecaptcha.execute();
  }

  form.addEventListener('submit', handleSubmit);
</script>

<style>
  .empty-feedback {
    visibility: hidden;
  }

  .field-feedback {
    min-height: 1rem;
    visibility: hidden;
  }

  .was-validated input:placeholder-shown:invalid ~ .field-feedback {
    visibility: visible;
    content: 'Campo requerido.';
  }

  .was-validated input:not(:placeholder-shown):invalid[data-type='email'] ~ .field-feedback::after {
    content: 'Ingresa un correo válido.';
    visibility: visible;
  }

  .was-validated input:not(:placeholder-shown):invalid ~ .field-feedback::after {
    content: 'Ingresa un correo válido.';
  }

  .was-validated input:invalid ~ .field-feedback {
    visibility: hidden;
    position: relative;
  }

  .was-validated input:invalid ~ .field-feedback::after {
    visibility: visible;
    display: block;
    position: absolute;
    left: 0;
    top: 0;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    visibility: visible;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }
</style>
