---
import type { Form } from '~/types';
import Button from '~/components/ui/Button.astro';

const { inputs, textarea, disclaimer, button = 'Enviar Mensaje', description = '' } = Astro.props as Form;
---

<form id="my-form" action="https://formspree.io/f/mldbbkyp" method="POST" class="needs-validation" novalidate>
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <div class="mb-6">
              {label && (
                <label for={name} class="block text-sm font-medium mb-2 text-[#1a202ccc] dark:text-white">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={name}
                autocomplete={autocomplete}
                placeholder={placeholder}
                class="py-3 px-4 block w-full text-sm rounded-md border-2 border-solid border-[#ff880033] border-l-[#ff8800a8] bg-[#ff88000d] duration-[.3s] focus:outline-none focus:border-[#ff8800a2] focus:ring-[#ff8800a2] dark:border-gray-700 dark:bg-slate-900"
                required
              />
              <div class="empty-feedback text-red-400 text-sm mt-1">Campo requerido.</div>
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for="textarea" class="block text-sm font-medium mb-2 text-[#1a202ccc] dark:text-white">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name="message"
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          class="py-3 px-4 block w-full text-sm rounded-md border-2 border-solid border-[#ff880033] border-l-[#ff8800a8] bg-[#ff88000d] duration-[.3s] focus:outline-none focus:border-[#ff8800a2] focus:ring-[#ff8800a2] dark:border-gray-700 dark:bg-slate-900"
          required
        />
        <div class="empty-feedback invalid-feedback text-red-400 text-sm mt-1">Campo requerido.</div>
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer mt-1 py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="mt-10 grid">
        <div class="flex justify-center">
          <div class="g-recaptcha" data-sitekey="6LdfoTErAAAAAPrzJimGg1rMdhah7aSt1oKQIHT2" />
        </div>
        <div id="invalid-recaptcha" class="text-red-400 text-sm mt-1 mb-4 text-center" />
        <Button id="my-form-button" type="submit" variant="primary">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400">{description}</p>
      </div>
    )
  }
</form>

<script is:inline src="https://www.google.com/recaptcha/api.js" async defer></script>

<script is:inline>
  /* global grecaptcha */
  var form = document.getElementById('my-form');
  var button = document.getElementById('my-form-button');

  async function handleSubmit(event) {
    event.preventDefault();

    if (!form.checkValidity()) {
      form.classList.add('was-validated');
      form.querySelectorAll(':invalid')[0].focus();
      return;
    }

    button.disabled = true;

    var status = document.getElementById('my-form-status');
    var invalidRecaptcha = document.getElementById('invalid-recaptcha');
    var data = new FormData(event.target);

    fetch(event.target.action, {
      method: form.method,
      body: data,
      headers: {
        Accept: 'application/json',
      },
    })
      .then((response) => {
        if (response.ok) {
          form.reset();
          form.classList.remove('was-validated');
          invalidRecaptcha.innerHTML = '';
          if (typeof grecaptcha !== 'undefined') {
            grecaptcha.reset();
          }

          const toast = document.getElementById('form-success-toast');
          if (toast) {
            toast.classList.remove('opacity-0', 'pointer-events-none');
            toast.classList.add('opacity-100');
            setTimeout(() => {
              toast.classList.add('opacity-0', 'pointer-events-none');
              toast.classList.remove('opacity-100');
            }, 4000);
          }
        } else {
          response.json().then((data) => {
            if (Object.hasOwn(data, 'errors')) {
              status.innerHTML = data['errors'].map((error) => error['message']).join(', ');
            } else {
              invalidRecaptcha.innerHTML = data.error;
              setTimeout(() => {
                invalidRecaptcha.innerHTML = '';
              }, 5000);
            }
          });
        }
      })
      .catch((error) => {
        console.error(error);
        status.innerHTML = 'Oops! There was a problem submitting your form';
      })
      .finally(() => {
        button.disabled = false;
      });
  }
  form.addEventListener('submit', handleSubmit);
</script>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }
</style>
